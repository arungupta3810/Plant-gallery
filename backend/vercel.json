{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "prisma generate && prisma migrate deploy && nest build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "prisma/**",
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}

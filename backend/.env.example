# Backend environment — copy to .env and adjust
DATABASE_URL="postgresql://plant:plant@localhost:5432/plant_gallery?schema=public"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
# Comma-separated origins allowed to call the API
CORS_ORIGIN="http://localhost:3000"

# Email (Resend — https://resend.com). Free tier: 3,000 emails/mo.
# Get a key at resend.com → API Keys (starts with "re_"). Leave blank to
# run in dev mode, where emails are logged to the console instead of sent.
RESEND_API_KEY=""
# Sender address. "onboarding@resend.dev" works immediately for testing.
# For production, verify your own domain in Resend and use an address on it.
EMAIL_FROM="Plant Gallery <onboarding@resend.dev>"
